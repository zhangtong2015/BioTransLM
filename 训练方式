### 早停与检查点
```python
class TrainingMonitor:
    def __init__(self, patience=5, save_dir='checkpoints/'):
        self.patience = patience
        self.save_dir = save_dir
        self.best_metric = -float('inf')
        self.counter = 0
        self.metrics_history = {}
        
    def check_early_stopping(self, current_metrics):
        """检查是否需要早停"""
        primary_metric = self._get_primary_metric(current_metrics)
        
        if primary_metric > self.best_metric:
            self.best_metric = primary_metric
            self.counter = 0
            self._save_checkpoint('best_model.pt')
            return False
        else:
            self.counter += 1
            if self.counter >= self.patience:
                print(f"Early stopping after {self.patience} epochs")
                return True
            return False
    
    def _save_checkpoint(self, filename):
        """保存稀疏模型检查点
        
        注意: HTM/SNN模型保存稀疏连接
        - 仅保存非零权重
        - 使用高效的稀疏格式存储
        - 检查点大小仅为Transformer的~10%
        """
        sparse_checkpoint = {
            'model_state': self.model.sparse_state_dict(),
            'optimizer_state': self.optimizer.state_dict(),
            'metrics': self.metrics_history,
            'config': self.config
        }
        torch.save(sparse_checkpoint, os.path.join(self.save_dir, filename))
```

