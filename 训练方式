## 🔬 损失函数设计

### 1. 多层级损失函数体系

```python
class BioTransLMLoss:
    """
    生物启发式多层级损失函数
    无Transformer依赖，纯生物机制
    """
    
    def __init__(self, config):
        self.config = config
        self.loss_weights = {
            'reconstruction': 1.0,
            'sparsity': 0.1,
            'temporal': 0.05,
            'prediction': 1.0,
            'stdp': 0.01,
            'attention': 0.05,
            'regulation': 0.02,
            'memory': 0.03,
        }
    
    def compute_total_loss(self, model_output, batch, model):
        """计算总损失"""
        loss_components = {}
        
        # 1. 重构损失
        loss_components['reconstruction'] = self.reconstruction_loss(
            model_output['recon_input'],
            batch['input_ids']
        )
        
        # 2. 稀疏性损失
        loss_components['sparsity'] = self.sparsity_loss(
            model_output['htm_activations'],
            model_output['snn_spikes']
        )
        
        # 3. 时序预测损失
        loss_components['prediction'] = self.temporal_prediction_loss(
            model_output['htm_predictions'],
            model_output['actual_next_state']
        )
        
        # 4. 时序连续性损失
        loss_components['temporal'] = self.temporal_consistency_loss(
            model_output['htm_activations']
        )
        
        # 5. STDP奖励损失
        loss_components['stdp'] = self.stdp_reward_loss(
            model_output['spike_sequence'],
            model_output['prediction_accuracy']
        )
        
        # 6. 神经调节辅助损失
        loss_components['regulation'] = self.regulation_auxiliary_loss(
            model_output['regulation_signal'],
            model_output['prediction_error']
        )
        
        # 7. 记忆检索损失
        loss_components['memory'] = self.memory_retrieval_loss(
            model_output['memory_retrieval'],
            batch.get('relevant_memory_indices')
        )
        
        # 加权求和
        total_loss = 0
        for name, loss in loss_components.items():
            weight = self.loss_weights.get(name, 1.0)
            total_loss += weight * loss
        
        return total_loss, loss_components
    
    def reconstruction_loss(self, recon_logits, target_ids):
        """
        稀疏重构损失
        仅考虑非零激活位置
        """
        batch_size, seq_len, vocab_size = recon_logits.shape
        
        # 稀疏交叉熵：仅计算活跃位置
        loss = torch.nn.functional.cross_entropy(
            recon_logits.reshape(-1, vocab_size),
            target_ids.reshape(-1),
            reduction='none'
        )
        
        # 仅对非填充token计算损失
        if 'attention_mask' in target_ids:
            mask = target_ids.attention_mask.reshape(-1).bool()
            loss = loss[mask]
        
        return loss.mean()
    
    def sparsity_loss(self, htm_activations, snn_spikes=None):
        """
        稀疏性正则化损失
        目标：激活率 ~2%
        """
        # HTM激活稀疏度
        htm_activation_rate = (htm_activations.abs() > 1e-8).float().mean()
        htm_sparsity_loss = torch.abs(htm_activation_rate - self.config.target_activation_rate)
        
        # SNN脉冲稀疏度
        if snn_spikes is not None:
            snn_firing_rate = snn_spikes.float().mean()
            snn_sparsity_loss = torch.abs(snn_firing_rate - self.config.target_firing_rate)
            return htm_sparsity_loss + 0.5 * snn_sparsity_loss
        
        return htm_sparsity_loss
    
    def temporal_prediction_loss(self, predictions, actual_next):
        """
        时序预测损失
        HTM风格：预测与实际激活的重叠度
        """
        # 二值化预测和实际
        pred_binary = (predictions > 0.5).float()
        actual_binary = (actual_next.abs() > 1e-8).float()
        
        # 重叠分数：交集/并集
        intersection = (pred_binary * actual_binary).sum(dim=-1)
        union = pred_binary.sum(dim=-1) + actual_binary.sum(dim=-1) - intersection
        overlap = intersection / (union + 1e-8)
        
        # 最大化重叠 = 最小化(1 - 重叠)
        return (1 - overlap).mean()
    
    def temporal_consistency_loss(self, activations, window_size=5):
        """
        时序连续性损失
        相邻时间步的表示应该相似
        """
        batch_size, seq_len, _ = activations.shape
        
        if seq_len < 2:
            return 0
        
        # 计算相邻步的余弦相似度
        cos_sim = torch.nn.functional.cosine_similarity(
            activations[:, 1:],
            activations[:, :-1],
            dim=-1
        )
        
        # 最大化相似度 = 最小化(1 - 相似度)
        return (1 - cos_sim).mean()
    
    def stdp_reward_loss(self, spike_sequence, prediction_accuracy):
        """
        STDP奖励损失
        基于预测准确度的奖励调制学习
        """
        # 如果预测准确，加强近期的STDP更新
        reward = prediction_accuracy - 0.5  # [-0.5, 0.5]
        
        # 脉冲发放率正则化：惩罚过高或过低的发放率
        firing_rate = spike_sequence.float().mean()
        rate_loss = torch.abs(firing_rate - self.config.optimal_firing_rate)
        
        return rate_loss * (1 - torch.tanh(reward))
    
    def regulation_auxiliary_loss(self, reg_signal, prediction_error):
        """
        神经调节器辅助损失
        鼓励根据预测误差适当调节
        """
        # 高误差时应提高注意力强度
        target_attention = torch.sigmoid(prediction_error * 5)
        attention_loss = torch.nn.functional.mse_loss(
            reg_signal['attention_strength'],
            target_attention
        )
        
        # 系统偏差：高误差时应偏向System2
        target_system2_bias = torch.sigmoid(prediction_error * 3)
        system_bias_loss = torch.nn.functional.mse_loss(
            reg_signal['system2_bias'],
            target_system2_bias
        )
        
        return attention_loss + system_bias_loss
    
    def memory_retrieval_loss(self, retrieval_results, relevant_indices=None):
        """
        记忆检索损失
        鼓励检索到相关记忆
        """
        if relevant_indices is None:
            return 0
        
        # 计算检索到的记忆与相关记忆的重叠度
        retrieved = retrieval_results['retrieved_indices']
        relevance_score = self._compute_retrieval_relevance(retrieved, relevant_indices)
        
        return 1 - relevance_score
