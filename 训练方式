class TrainingMonitor:
    """训练监控与可视化"""
    
    def __init__(self, log_dir='logs/'):
        from torch.utils.tensorboard import SummaryWriter
        self.writer = SummaryWriter(log_dir=log_dir)
        self.step = 0
    
    def log_scalars(self, metrics, prefix=''):
        """记录标量指标"""
        for name, value in metrics.items():
            if isinstance(value, (int, float)):
                self.writer.add_scalar(f'{prefix}/{name}', value, self.step)
            elif torch.is_tensor(value) and value.numel() == 1:
                self.writer.add_scalar(f'{prefix}/{name}', value.item(), self.step)
    
    def log_activation_histogram(self, activations, name='activations'):
        """记录激活分布直方图"""
        self.writer.add_histogram(name, activations, self.step)
    
    def log_sparsity_heatmap(self, activations, name='sparsity'):
        """稀疏度热力图可视化"""
        if len(activations.shape) >= 3:
            # 取第一个样本的时间步平均
            data = (activations[0].abs() > 1e-8).float().cpu().numpy()
            self.writer.add_image(name, data.T, self.step, dataformats='HW')
    
    def log_spike_raster(self, spikes, name='spike_raster'):
        """脉冲发放光栅图"""
        if len(spikes.shape) >= 3:
            data = spikes[0].cpu().numpy()  # [seq_len, n_neurons]
            self.writer.add_image(name, data.T, self.step, dataformats='HW')

    def log_attention_map(self, attention_map, name='attention'):
        """注意力图可视化"""
        if len(attention_map.shape) >= 3:
            data = attention_map[0].cpu().numpy()
            self.writer.add_image(name, data, self.step, dataformats='HW')
