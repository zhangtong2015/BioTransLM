## 🔧 训练优化与效率

### 1. 稀疏计算优化
```python
class SparseComputeOptimizer:
    """稀疏计算优化器"""
    
    def __init__(self, model, config):
        self.model = model
        self.config = config
        
    def sparse_forward(self, x):
        """仅计算激活的连接"""
        batch_size = x.shape[0]
        
        # 1. 找到激活的输入特征
        active_inputs = x.abs() > self.config.sparsity_eps
        
        # 2. 仅对激活的输入执行矩阵乘法
        output = torch.zeros(
            batch_size, self.config.n_columns, 
            device=x.device
        )
        
        for b in range(batch_size):
            active_idx = active_inputs[b].nonzero(as_tuple=True)[0]
            if len(active_idx) > 0:
                # 稀疏乘法: 仅取活跃部分
                active_weights = self.model.weights[:, active_idx]
                output[b] = torch.sparse.mm(active_weights, x[b, active_idx].unsqueeze(1)).squeeze()
        
        return output
    
    def sparse_backward(self, grad_output):
        """仅更新激活的突触"""
        # 梯度稀疏化: 只保留最大的k%梯度
        grad_sparse = topk_sparsify(
            grad_output, 
            k=int(self.config.n_columns * 0.02)
        )
        return grad_sparse
```

