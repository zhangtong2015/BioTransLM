## 🔄 训练循环核心实现

### 主训练循环

```python
class BioTransLMTrainer:
    """
    BioTransLM 训练器核心
    完全非Transformer架构，纯生物启发式
    """
    
    def __init__(self, model, config, device='cuda' if torch.cuda.is_available() else 'cpu'):
        self.model = model
        self.config = config
        self.device = device
        self.model.to(device)
        
        # 损失函数
        self.criterion = BioTransLMLoss(config.training)
        
        # 稀疏优化器
        self.optimizer = SparseAdam(
            [p for p in model.parameters() if p.requires_grad],
            lr=config.training.learning_rate,
            betas=(0.9, 0.999)
        )
        
        # 学习率调度
        self.scheduler = torch.optim.lr_scheduler.CosineAnnealingWarmRestarts(
            self.optimizer,
            T_0=10,
            T_mult=2
        )
        
        # 数据适配器（兼容Transformer数据集）
        self.data_adapter = TransformerDataAdapter(
            tokenizer_name=config.data.tokenizer_name
        )
        
        # 训练状态
        self.current_epoch = 0
        self.current_step = 0
        self.best_metric = float('inf')
        
        # 监控指标
        self.metrics_history = {
            'train': defaultdict(list),
            'val': defaultdict(list)
        }
        
        # 容错处理
        self.fault_handler = FaultToleranceHandler(config)
        
        # 梯度缩放（用于混合精度）
        self.scaler = torch.cuda.amp.GradScaler(
            enabled=config.training.use_amp
        )
    
    def train(self, train_dataset, val_dataset=None, num_epochs=10):
        """主训练入口"""
        logger.info(f"开始训练，共 {num_epochs} 轮")
        
        for epoch in range(num_epochs):
            self.current_epoch = epoch
            
            # 训练阶段
            train_metrics = self._train_epoch(train_dataset)
            
            # 验证阶段
            val_metrics = {}
            if val_dataset is not None:
                val_metrics = self._validate_epoch(val_dataset)
            
            # 更新调度器
            self.scheduler.step()
            
            # 保存检查点
            self._save_checkpoint('latest.pt')
            
            # 早停检查
            if val_dataset and self._check_early_stopping(val_metrics):
                logger.info("早停触发，训练结束")
                break
        
        logger.info("训练完成")
    
    def _train_epoch(self, dataset):
        """单轮训练"""
        self.model.train()
        epoch_metrics = defaultdict(float)
        
        for batch_idx, batch in enumerate(dataset):
            self.current_step += 1
            
            try:
                batch_metrics = self._train_step(batch, batch_idx)
                
                # 累积指标
                for k, v in batch_metrics.items():
                    epoch_metrics[k] += v
                
                # 日志
                if batch_idx % self.config.training.log_interval == 0:
                    self._log_step(batch_idx, batch_metrics, 'train')
                
                # 验证检查点
                if (self.current_step % self.config.training.val_interval == 0 and 
                    self.current_step > 0):
                    self._run_validation_check()
                
            except BioTransLMError as e:
                recovery = self.fault_handler.handle_error(e, {
                    'batch_idx': batch_idx,
                    'step': self.current_step
                })
                if not recovery['recovered']:
                    raise
        
        # 计算平均指标
        avg_metrics = {k: v / len(dataset) for k, v in epoch_metrics.items()}
        self.metrics_history['train']['epoch'].append(avg_metrics)
        
        return avg_metrics
    
    @torch.cuda.amp.autocast()
    def _train_step(self, batch, batch_idx):
        """单步训练"""
        # 1. 数据转换：Transformer格式 → BioTransLM格式
        htm_input = self.data_adapter.to_htm_input(batch)
        
        # 转移到设备
        htm_input = self._batch_to_device(htm_input)
        
        # 2. 前向传播
        with torch.set_grad_enabled(True):
            model_output = self.model(
                htm_input['sparse'],
                attention_mask=htm_input.get('attention_mask'),
                task_context=batch.get('task_type'),
                training=True
            )
            
            # 3. 计算损失
            total_loss, loss_components = self.criterion.compute_total_loss(
                model_output,
                batch,
                self.model
            )
        
        # 4. 反向传播（稀疏更新）
        self._sparse_backward(total_loss)
        
        # 5. 梯度裁剪（防止爆炸）
        torch.nn.utils.clip_grad_norm_(
            self.model.parameters(),
            max_norm=self.config.training.max_grad_norm
        )
        
        # 6. 优化器步进
        self.optimizer.step()
        self.optimizer.zero_grad(set_to_none=True)
        
        # 7. 准备指标
        metrics = {
            'total_loss': total_loss.item(),
            'learning_rate': self.scheduler.get_last_lr()[0],
            **{f'loss_{k}': v.item() if torch.is_tensor(v) else v 
               for k, v in loss_components.items()},
            **self._compute_batch_metrics(model_output, batch)
        }
        
        return metrics
    
    def _sparse_backward(self, loss):
        """
        稀疏反向传播
        仅更新有激活的连接
        """
        # 常规反向传播
        self.scaler.scale(loss).backward()
        
        # 稀疏化梯度：仅保留非零激活对应的梯度
        for name, param in self.model.named_parameters():
            if param.grad is not None:
                if 'htm' in name or 'snn' in name or 'sparse' in name:
                    # 应用稀疏掩码：仅保留最大的k%梯度
                    param.grad.data = self._sparsify_gradient(
                        param.grad.data,
                        sparsity_level=self.config.training.grad_sparsity
                    )
    
    def _sparsify_gradient(self, grad, sparsity_level=0.9):
        """梯度稀疏化"""
        if grad.numel() == 0:
            return grad
        
        # 保留绝对值最大的k%元素
        k = int(grad.numel() * (1 - sparsity_level))
        if k <= 0:
            return torch.zeros_like(grad)
        
        flat_grad = grad.abs().flatten()
        topk_values, _ = torch.topk(flat_grad, k)
        threshold = topk_values[-1] if k > 0 else 0
        
        mask = (grad.abs() >= threshold).float()
        return grad * mask
    
    def _validate_epoch(self, dataset):
        """验证阶段"""
        self.model.eval()
        val_metrics = defaultdict(float)
        
        with torch.no_grad():
            for batch_idx, batch in enumerate(dataset):
                htm_input = self.data_adapter.to_htm_input(batch)
                htm_input = self._batch_to_device(htm_input)
                
                model_output = self.model(
                    htm_input['sparse'],
                    attention_mask=htm_input.get('attention_mask'),
                    task_context=batch.get('task_type'),
                    training=False
                )
                
                _, loss_components = self.criterion.compute_total_loss(
                    model_output, batch, self.model
                )
                
                batch_metrics = {
                    **{f'loss_{k}': v.item() if torch.is_tensor(v) else v 
                       for k, v in loss_components.items()},
                    **self._compute_batch_metrics(model_output, batch)
                }
                
                for k, v in batch_metrics.items():
                    val_metrics[k] += v
                
                if batch_idx % self.config.training.log_interval == 0:
                    self._log_step(batch_idx, batch_metrics, 'val')
        
        # 平均指标
        avg_metrics = {k: v / len(dataset) for k, v in val_metrics.items()}
        self.metrics_history['val']['epoch'].append(avg_metrics)
        
        return avg_metrics
    
    def _compute_batch_metrics(self, model_output, batch):
        """计算批次级别的评估指标"""
        metrics = {}
        
        # 稀疏度指标
        if 'htm_activations' in model_output:
            acts = model_output['htm_activations']
            metrics['sparsity'] = ((acts.abs() < 1e-8).float().mean() * 100).item()
        
        # 预测准确率
        if 'prediction_accuracy' in model_output:
            metrics['pred_accuracy'] = model_output['prediction_accuracy'].mean().item()
        
        # SNN指标
        if 'spike_sequence' in model_output:
            spikes = model_output['spike_sequence']
            metrics['firing_rate_hz'] = spikes.float().mean().item() * 1000  # 假设1ms时间步
        
        return metrics
    
    def _batch_to_device(self, batch):
        """将批次数据移动到指定设备"""
        device_batch = {}
        for k, v in batch.items():
            if isinstance(v, torch.Tensor):
                device_batch[k] = v.to(self.device)
            elif isinstance(v, dict):
                device_batch[k] = self._batch_to_device(v)
            else:
                device_batch[k] = v
        return device_batch
    
    def _save_checkpoint(self, filename):
        """保存检查点（稀疏格式）"""
        checkpoint_dir = Path(self.config.training.checkpoint_dir)
        checkpoint_dir.mkdir(exist_ok=True, parents=True)
        
        # 稀疏状态字典：仅保存非零参数
        sparse_state_dict = {}
        for name, param in self.model.state_dict().items():
            if param.dtype in [torch.float32, torch.float16]:
                # 转换为稀疏张量节省空间
                if param.numel() > 1000:  # 大张量使用稀疏
                    sparse_param = param.to_sparse()
                    sparse_state_dict[name] = {
                        'data': sparse_param,
                        'is_sparse': True,
                        'shape': tuple(param.shape)
                    }
                else:
                    sparse_state_dict[name] = {
                        'data': param,
                        'is_sparse': False,
                        'shape': tuple(param.shape)
                    }
        
        checkpoint = {
            'epoch': self.current_epoch,
            'step': self.current_step,
            'model_state_dict': sparse_state_dict,
            'optimizer_state_dict': self.optimizer.state_dict(),
            'scheduler_state_dict': self.scheduler.state_dict(),
            'scaler_state_dict': self.scaler.state_dict(),
            'metrics': self.metrics_history,
            'config': self.config.dict(),
            'best_metric': self.best_metric
        }
        
        torch.save(checkpoint, checkpoint_dir / filename)
        logger.info(f"检查点已保存: {checkpoint_dir / filename}")
