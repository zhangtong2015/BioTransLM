# scripts/train_distributed.py
import torch
import torch.distributed as dist
from torch.nn.parallel import DistributedDataParallel as DDP
from torch.utils.data import DataLoader, DistributedSampler

def setup_ddp(rank, world_size):
    """设置分布式训练环境"""
    os.environ['MASTER_ADDR'] = 'localhost'
    os.environ['MASTER_PORT'] = '12355'
    
    dist.init_process_group("nccl", rank=rank, world_size=world_size)
    torch.cuda.set_device(rank)

def cleanup_ddp():
    dist.destroy_process_group()

def train_ddp(rank, world_size, config):
    """分布式训练函数"""
    setup_ddp(rank, world_size)
    
    # 创建模型和数据集
    model = BioTransLM(config.model)
    model = model.to(rank)
    model = DDP(model, device_ids=[rank], find_unused_parameters=True)
    
    dataset = load_biotranslm_dataset(config.data)
    sampler = DistributedSampler(dataset, num_replicas=world_size, rank=rank)
    dataloader = DataLoader(dataset, batch_size=config.data.batch_size, sampler=sampler)
    
    trainer = BioTransLMTrainer(model.module, config, device=f'cuda:{rank}')
    
    for epoch in range(config.training.num_epochs):
        sampler.set_epoch(epoch)
        trainer._train_epoch(dataloader)
        
        if rank == 0:  # 只在主进程保存和验证
            trainer._save_checkpoint(f'epoch_{epoch}.pt')
    
    cleanup_ddp()

if __name__ == "__main__":
    world_size = torch.cuda.device_count()
    config = load_config('configs/training.yaml')
    
    torch.multiprocessing.spawn(
        train_ddp,
        args=(world_size, config),
        nprocs=world_size,
        join=True
    )
